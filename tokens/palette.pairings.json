{
  "$comment": "Palette-gate contract for Robert DeLanghe's brand tokens. Declares every real foreground/background pairing the semantic tokens are designed for, plus the categorical status set. The gate (vendor/conformance-kit/gates/palette-gate.mjs) resolves fg/bg against the generated tokens.css and fails closed on any WCAG-AA, CVD-safe (deuteranopia/protanopia/tritanopia), APCA, or non-text (WCAG 1.4.11) violation. No decorative exemptions: hairlines/dividers are declared as `ui` and must clear 3:1.",
  "$apca": "kind=text uses the gate's APCA floor (minLcText, 60). PRIMARY BODY pairings additionally declare size/weight, invoking the gate's size-aware APCA comfort tier (Lc>=90 at 16px). Secondary/label/accent roles are held to the APCA baseline floor (Lc>=60).",
  "thresholds": {
    "minRatioText": 4.5,
    "minRatioLarge": 3.0,
    "minRatioUi": 3.0,
    "minLcText": 60,
    "minLcLarge": 45,
    "collapseDeltaE": 10
  },
  "pairings": [
    { "name": "body / ink on paper", "fg": "ink", "bg": "paper", "kind": "text", "size": 16, "weight": 400 },
    { "name": "body / ink on card", "fg": "ink", "bg": "card", "kind": "text", "size": 16, "weight": 400 },

    { "name": "secondary / ink-soft on paper", "fg": "ink-soft", "bg": "paper", "kind": "text" },
