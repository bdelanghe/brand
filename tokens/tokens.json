{
  "$description": "Robert DeLanghe personal brand tokens. Source of truth. Three tiers: primitive (raw palette, hue-named) → color (semantic roles, purpose-named, alias primitives) → text (component recipes). Edit here; regenerate tokens.css via build-tokens.mjs. Only the semantic/recipe layers are emitted as --bs-*; primitives are the source-of-truth palette the semantics point at (change a primitive → every role that aliases it updates). Semantic names must describe purpose, not hue — a recolor should never require a rename.",
  "primitive": {
    "$description": "Raw palette. Not emitted directly — referenced by the semantic color tier. Theming = change a primitive once.",
    "paper": { "$type": "color", "$value": "#EDEAE1", "$description": "Warm paper" },
    "white": { "$type": "color", "$value": "#FFFFFF" },
    "cream": { "$type": "color", "$value": "#F4F1EA", "$description": "Warm off-white" },
    "ink-900": { "$type": "color", "$value": "#16221C", "$description": "Near-black ink" },
    "ink-600": { "$type": "color", "$value": "#5C6B63", "$description": "Muted ink" },
    "ink-500": { "$type": "color", "$value": "#5E6B62", "$description": "Mono-label ink (WCAG-AA on paper)" },
    "line": { "$type": "color", "$value": "#E4E0D4", "$description": "Hairline" },
    "clay-800": { "$type": "color", "$value": "#783022", "$description": "Clay, pressed/deep" },
    "clay-600": { "$type": "color", "$value": "#A6432F", "$description": "Clay — brick/terracotta" },
    "clay-200": { "$type": "color", "$value": "#E0BDB6", "$description": "Clay soft" },
    "clay-100": { "$type": "color", "$value": "#F2DED8", "$description": "Clay wash" },
    "amber-600": { "$type": "color", "$value": "#B5762A", "$description": "Amber" },
    "amber-100": { "$type": "color", "$value": "#F3E8D6", "$description": "Amber wash" },
    "red-600": { "$type": "color", "$value": "#B3261E", "$description": "Error red — deliberately distinct from clay, so the brand accent and a failure state never share a hex" },
    "red-100": { "$type": "color", "$value": "#F4DEDD", "$description": "Error wash" }
  },
  "color": {
    "$description": "Semantic roles. Purpose-named — never hue-named — so a recolor (change which primitive a role aliases) never forces a rename here or in any consumer's CSS.",
    "accent": { "$type": "color", "$value": "{primitive.clay-600}", "$description": "Primary brand fill" },
    "accent-strong": { "$type": "color", "$value": "{primitive.clay-800}", "$description": "Pressed / deep surfaces" },
    "accent-tint": { "$type": "color", "$value": "{primitive.clay-100}", "$description": "Subtle tinted surface" },
    "accent-soft": { "$type": "color", "$value": "{primitive.clay-200}", "$description": "Fills/borders on tinted surfaces" },
    "on-accent": { "$type": "color", "$value": "{primitive.white}", "$description": "Mark / text rendered on an accent-colored surface" },
    "paper": { "$type": "color", "$value": "{primitive.paper}", "$description": "App background, warm" },
    "card": { "$type": "color", "$value": "{primitive.white}", "$description": "Card surface" },
    "card-alt": { "$type": "color", "$value": "{primitive.cream}", "$description": "Light avatar fill" },
    "ink": { "$type": "color", "$value": "{primitive.ink-900}", "$description": "Primary text" },
    "ink-soft": { "$type": "color", "$value": "{primitive.ink-600}", "$description": "Secondary text" },
    "ink-mono": { "$type": "color", "$value": "{primitive.ink-500}", "$description": "Mono label / slug text" },
    "line": { "$type": "color", "$value": "{primitive.line}", "$description": "Hairline borders" },
    "status-warning": { "$type": "color", "$value": "{primitive.amber-600}", "$description": "Caution / highlight" },
    "status-warning-tint": { "$type": "color", "$value": "{primitive.amber-100}", "$description": "Caution surface" },
    "status-negative": { "$type": "color", "$value": "{primitive.red-600}", "$description": "Error / negative state — intentionally NOT the same primitive as accent" },
    "status-negative-tint": { "$type": "color", "$value": "{primitive.red-100}", "$description": "Negative surface" }
  },
  "font": {
    "display": {
      "$type": "fontFamily",
      "$value": [
        "Space Grotesk",
        "sans-serif"
      ],
      "$description": "Headings & UI"
    },
    "mono": {
      "$type": "fontFamily",
      "$value": [
        "IBM Plex Mono",
        "monospace"
      ],
      "$description": "Labels, slugs, code"
    }
  },
  "size": {
    "text-h1": {
      "$type": "dimension",
      "$value": "46px"
    },
    "text-h2": {
      "$type": "dimension",
      "$value": "26px"
    },
    "text-title": {
      "$type": "dimension",
      "$value": "18px"
    },
    "text-body": {
      "$type": "dimension",
      "$value": "15px"
    },
    "text-label": {
      "$type": "dimension",
      "$value": "11px"
    }
  },
  "radius": {
    "radius-lg": {
      "$type": "dimension",
      "$value": "18px",
      "$description": "Cards, large surfaces"
    },
    "radius-md": {
      "$type": "dimension",
      "$value": "12px",
      "$description": "Inputs, small surfaces"
    }
  },
  "grade": {
    "$description": "Graded-claim status colours. Base only — build-tokens.mjs derives -bg (light surface) and -fg (readable text) tints deterministically.",
    "enforced": {
      "$type": "color",
      "$value": "#3FB984",
      "$description": "Proven/enforced in running code"
    },
    "partial": {
      "$type": "color",
      "$value": "#C8902F",
      "$description": "Partially enforced"
    },
    "aspirational": {
      "$type": "color",
      "$value": "#7E8C83",
      "$description": "Aspirational / not yet enforced"
    }
  },
  "text": {
    "h1": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.display}",
        "fontSize": "{size.text-h1}",
        "fontWeight": 600,
        "lineHeight": 1.02,
        "letterSpacing": "-0.025em"
      }
    },
    "h2": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.display}",
        "fontSize": "{size.text-h2}",
        "fontWeight": 600,
        "lineHeight": 1.1,
        "letterSpacing": "-0.02em"
      }
    },
    "title": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.display}",
        "fontSize": "{size.text-title}",
        "fontWeight": 600,
        "lineHeight": 1.3,
        "letterSpacing": "-0.01em"
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.display}",
        "fontSize": "{size.text-body}",
        "fontWeight": 400,
        "lineHeight": 1.5,
        "letterSpacing": "0"
      }
    },
    "label": {
      "$type": "typography",
      "$description": "Slug / eyebrow: mono uppercase tracked label.",
      "$value": {
        "fontFamily": "{font.mono}",
        "fontSize": "{size.text-label}",
        "fontWeight": 500,
        "lineHeight": 1,
        "letterSpacing": "0.14em",
        "textTransform": "uppercase"
      }
    }
  }
}
